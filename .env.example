PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/wavecom-notifications
# or mongodb+srv://<username>:<password>@cluster.mongodb.net/wavecom-notificationsRABBITMQ_URL=amqp://guest:guest@localhost:5672
REDIS_URL=redis://localhost:6379
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=WaveCom <notifications@yourdomain.com>
LOG_LEVEL=info
CORS_ORIGIN=*
USE_REAL_SMS=true
USE_REAL_PUSH=true
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="your_firebase_private_key"